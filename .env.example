# ===========================================================================
# Environment variables for Plainly
#
# Copy this file to .env.local and fill in real values as you wire up
# live data sources, auth, and other services. None of these are required
# to run the app with placeholder data.
# ===========================================================================

# --- Civic data provider (choose one) ---
# Google Civic Information API — free tier, 25,000 queries/day.
# Get a key at https://console.cloud.google.com (enable "Civic Information API",
# then create an API key under APIs & Services -> Credentials).
# Without this key, the app falls back to placeholder data automatically.
CIVIC_DATA_API_KEY=

# --- Geocoding (address/ZIP -> lat/lng -> district) ---
# Example if using Google Maps Geocoding API:
# GEOCODING_API_KEY=

# --- Auth & saved locations (Supabase) ---
# Create a free project at https://supabase.com, then run supabase/schema.sql
# in the SQL Editor. Find these values under Project Settings -> API.
# Without these, the app works fully as a guest experience — sign-in UI
# simply shows a "not configured" message.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — only used server-side by the reminders cron job.
# Found under Project Settings -> API -> service_role. NEVER expose this
# to the browser or prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Election reminder emails (Resend) ---
# Create a free account at https://resend.com and get an API key.
# Without this, the reminders cron job logs what it *would* send instead of
# sending real email — safe to leave unset during development.
RESEND_API_KEY=
# Must be on a domain you've verified in Resend, or use the default below
# for testing (only delivers to your own verified Resend account email).
EMAIL_FROM_ADDRESS="Plainly <onboarding@resend.dev>"

# Shared secret for the reminders cron endpoint. Set this to a random string
# and Vercel Cron will send it automatically as a Bearer token. If unset,
# the endpoint is unauthenticated (fine for local dev only).
CRON_SECRET=
